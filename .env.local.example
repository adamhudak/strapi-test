# URL of your Strapi instance — exposed to the browser (used by the lead form).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Hostname only (no protocol), used by next/image remotePatterns in production.
NEXT_PUBLIC_STRAPI_MEDIA_HOST=muravo-cms.example.com

# Server-only read token (Settings → API Tokens → Read-only) — never prefix with NEXT_PUBLIC_.
STRAPI_API_TOKEN=

# Shared secret between Strapi webhook and Next.js revalidation endpoint.
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=
